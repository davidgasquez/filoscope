#!/usr/bin/env node

import { spawnSync } from "node:child_process";
import { mkdir, mkdtemp, rename, rm, writeFile } from "node:fs/promises";
import { basename, dirname, resolve } from "node:path";

const DISCUSSION_PAGE_SIZE = 100;
const COMMENT_PAGE_SIZE = 100;
const REPLY_PAGE_SIZE = 100;

const args = process.argv.slice(2);
if (args.includes("-h") || args.includes("--help")) {
  console.error("Usage: gh-discussions <owner/repo|github-url> <output-dir>");
  process.exit(0);
}
if (args.length !== 2) {
  console.error("Usage: gh-discussions <owner/repo|github-url> <output-dir>");
  process.exit(1);
}

const repo = parseRepo(args[0]);
const outputDir = resolve(args[1]);

await dumpDiscussions(repo, outputDir);

async function dumpDiscussions(repo, outputDir) {
  const parent = dirname(outputDir);
  await mkdir(parent, { recursive: true });
  const tempDir = await mkdtemp(resolve(parent, `.${basename(outputDir)}-`));

  try {
    const discussions = await fetchDiscussions(repo);
    for (const [index, discussion] of discussions.entries()) {
      const expectedCommentCount = discussion.comments.totalCount;
      discussion.comments = await fetchComments(repo, discussion.number);
      if (discussion.comments.length !== expectedCommentCount) {
        throw new Error(`Discussion #${discussion.number}: expected ${expectedCommentCount} comments, fetched ${discussion.comments.length}`);
      }
      await writeFile(
        resolve(tempDir, `${String(discussion.number).padStart(5, "0")}-${slug(discussion.title)}.md`),
        renderDiscussion(repo, discussion),
        "utf8",
      );
      process.stderr.write(`Wrote discussion ${index + 1}/${discussions.length}: #${discussion.number}\n`);
    }

    await writeFile(resolve(tempDir, "README.md"), renderIndex(repo, discussions), "utf8");
    await rm(outputDir, { recursive: true, force: true });
    await rename(tempDir, outputDir);
    process.stderr.write(`Dumped ${discussions.length} discussions to ${outputDir}\n`);
  } catch (error) {
    await rm(tempDir, { recursive: true, force: true });
    throw error;
  }
}

async function fetchDiscussions(repo) {
  const query = `
    query($owner: String!, $name: String!, $after: String) {
      repository(owner: $owner, name: $name) {
        discussions(first: ${DISCUSSION_PAGE_SIZE}, after: $after) {
          totalCount
          pageInfo { hasNextPage endCursor }
          nodes {
            id
            number
            title
            url
            createdAt
            updatedAt
            closed
            closedAt
            upvoteCount
            body
            author { login }
            category { name emoji }
            comments { totalCount }
            isAnswered
            answerChosenAt
            answerChosenBy { login }
            answer {
              id
              url
              createdAt
              updatedAt
              upvoteCount
              author { login }
              body
            }
          }
        }
      }
    }
  `;

  const discussions = [];
  let after;
  let expectedCount;

  do {
    const data = ghGraphql(query, { owner: repo.owner, name: repo.name, after });
    const connection = data.repository?.discussions;
    if (!connection) throw new Error(`Repository not found or discussions unavailable: ${repo.owner}/${repo.name}`);

    expectedCount ??= connection.totalCount;
    discussions.push(...connection.nodes);
    after = connection.pageInfo.hasNextPage ? connection.pageInfo.endCursor : undefined;
  } while (after);

  if (discussions.length !== expectedCount) {
    throw new Error(`Expected ${expectedCount} discussions, fetched ${discussions.length}`);
  }
  return discussions.sort((a, b) => a.number - b.number);
}

async function fetchComments(repo, number) {
  const query = `
    query($owner: String!, $name: String!, $number: Int!, $after: String) {
      repository(owner: $owner, name: $name) {
        discussion(number: $number) {
          comments(first: ${COMMENT_PAGE_SIZE}, after: $after) {
            pageInfo { hasNextPage endCursor }
            nodes {
              id
              url
              createdAt
              updatedAt
              upvoteCount
              authorAssociation
              isAnswer
              author { login }
              body
              replies(first: ${REPLY_PAGE_SIZE}) {
                totalCount
                pageInfo { hasNextPage endCursor }
                nodes {
                  id
                  url
                  createdAt
                  updatedAt
                  upvoteCount
                  authorAssociation
                  isAnswer
                  author { login }
                  body
                }
              }
            }
          }
        }
      }
    }
  `;

  const comments = [];
  let after;

  do {
    const data = ghGraphql(query, { owner: repo.owner, name: repo.name, number, after });
    const connection = data.repository?.discussion?.comments;
    if (!connection) throw new Error(`Discussion not found: ${repo.owner}/${repo.name}#${number}`);

    for (const comment of connection.nodes) {
      if (comment.replies.pageInfo.hasNextPage) {
        comment.replies.nodes.push(...await fetchMoreReplies(comment.id, comment.replies.pageInfo.endCursor));
      }
      if (comment.replies.nodes.length !== comment.replies.totalCount) {
        throw new Error(`Comment ${comment.id}: expected ${comment.replies.totalCount} replies, fetched ${comment.replies.nodes.length}`);
      }
      comments.push(comment);
    }
    after = connection.pageInfo.hasNextPage ? connection.pageInfo.endCursor : undefined;
  } while (after);

  return comments;
}

async function fetchMoreReplies(commentId, after) {
  const query = `
    query($commentId: ID!, $after: String) {
      node(id: $commentId) {
        ... on DiscussionComment {
          replies(first: ${REPLY_PAGE_SIZE}, after: $after) {
            pageInfo { hasNextPage endCursor }
            nodes {
              id
              url
              createdAt
              updatedAt
              upvoteCount
              authorAssociation
              isAnswer
              author { login }
              body
            }
          }
        }
      }
    }
  `;

  const replies = [];
  while (after) {
    const data = ghGraphql(query, { commentId, after });
    const connection = data.node?.replies;
    if (!connection) throw new Error(`Comment not found: ${commentId}`);

    replies.push(...connection.nodes);
    after = connection.pageInfo.hasNextPage ? connection.pageInfo.endCursor : undefined;
  }
  return replies;
}

function ghGraphql(query, variables) {
  const args = ["api", "graphql", "-f", `query=${query}`];
  for (const [key, value] of Object.entries(variables)) {
    if (value === undefined) continue;
    args.push(Number.isInteger(value) ? "-F" : "-f", `${key}=${value}`);
  }

  const result = spawnSync("gh", args, { encoding: "utf8", maxBuffer: 1024 * 1024 * 64 });
  if (result.error) throw result.error;
  if (result.status !== 0) {
    throw new Error((result.stderr || result.stdout || `gh api graphql failed with exit code ${result.status}`).trim());
  }

  const payload = JSON.parse(result.stdout);
  if (payload.errors?.length) {
    throw new Error(payload.errors.map((error) => error.message).join("\n"));
  }
  return payload.data;
}

function renderDiscussion(repo, discussion) {
  const lines = [
    `# #${discussion.number} ${discussion.title}`,
    "",
    `Repository: ${repo.owner}/${repo.name}`,
    `URL: ${discussion.url}`,
    `Category: ${discussion.category?.emoji ?? ""} ${discussion.category?.name ?? "Uncategorized"}`.trimEnd(),
    `Author: ${user(discussion.author)}`,
    `Created: ${discussion.createdAt}`,
    `Updated: ${discussion.updatedAt}`,
    `Closed: ${discussion.closed ? `yes${discussion.closedAt ? ` (${discussion.closedAt})` : ""}` : "no"}`,
    `Upvotes: ${discussion.upvoteCount}`,
    `Comments: ${discussion.comments.length}`,
    "",
    "## Discussion",
    "",
    body(discussion.body),
    "",
  ];

  if (discussion.answer) {
    lines.push(
      "## Accepted Answer",
      "",
      `Author: ${user(discussion.answer.author)}`,
      `URL: ${discussion.answer.url}`,
      `Chosen: ${discussion.answerChosenAt ?? "unknown"} by ${user(discussion.answerChosenBy)}`,
      `Created: ${discussion.answer.createdAt}`,
      `Updated: ${discussion.answer.updatedAt}`,
      `Upvotes: ${discussion.answer.upvoteCount}`,
      "",
      body(discussion.answer.body),
      "",
    );
  }

  lines.push("## Comments", "");
  if (discussion.comments.length === 0) {
    lines.push("No comments.", "");
  }

  for (const [commentIndex, comment] of discussion.comments.entries()) {
    lines.push(
      `### Comment ${commentIndex + 1} by ${user(comment.author)}`,
      "",
      `URL: ${comment.url}`,
      `Created: ${comment.createdAt}`,
      `Updated: ${comment.updatedAt}`,
      `Association: ${comment.authorAssociation}`,
      `Accepted answer: ${comment.isAnswer ? "yes" : "no"}`,
      `Upvotes: ${comment.upvoteCount}`,
      "",
      body(comment.body),
      "",
    );

    for (const [replyIndex, reply] of comment.replies.nodes.entries()) {
      lines.push(
        `#### Reply ${commentIndex + 1}.${replyIndex + 1} by ${user(reply.author)}`,
        "",
        `URL: ${reply.url}`,
        `Created: ${reply.createdAt}`,
        `Updated: ${reply.updatedAt}`,
        `Association: ${reply.authorAssociation}`,
        `Accepted answer: ${reply.isAnswer ? "yes" : "no"}`,
        `Upvotes: ${reply.upvoteCount}`,
        "",
        body(reply.body),
        "",
      );
    }
  }

  return `${lines.join("\n").replace(/\r\n/g, "\n").replace(/\r/g, "\n").trimEnd()}\n`;
}

function renderIndex(repo, discussions) {
  const lines = [
    `# GitHub Discussions for ${repo.owner}/${repo.name}`,
    "",
    `Total discussions: ${discussions.length}`,
    "",
  ];

  for (const discussion of discussions) {
    lines.push(`- [#${discussion.number} ${discussion.title}](${discussion.url})`);
  }
  return `${lines.join("\n")}\n`;
}

function parseRepo(value) {
  const normalized = value
    .trim()
    .replace(/^https:\/\/github\.com\//, "")
    .replace(/^git@github\.com:/, "")
    .replace(/\.git$/, "")
    .replace(/\/$/, "");
  const parts = normalized.split("/");
  if (parts.length !== 2 || parts.some((part) => part.trim() === "")) {
    throw new Error(`Expected GitHub repo as owner/name or GitHub URL, got: ${value}`);
  }
  return { owner: parts[0], name: parts[1] };
}

function slug(value) {
  const text = value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")
    .slice(0, 80);
  return text || "discussion";
}

function user(author) {
  return author?.login ? `@${author.login}` : "ghost";
}

function body(value) {
  const text = String(value ?? "").trim();
  return text === "" ? "_No body._" : text;
}
